# Copy to `.streamlit/secrets.toml` for local Streamlit, or paste equivalent keys in
# Streamlit Community Cloud → App settings → Secrets.
#
# GROQ_API_KEY = "gsk_..."
# Optional:
# GROQ_MODEL = "llama-3.3-70b-versatile"
# ZOMATO_PROCESSED_DATASET = "/absolute/path/to/restaurants.parquet"
# HF_TOKEN = "hf_..."   # only if your Hugging Face dataset requires auth
# HF_DATASET_ID = "your-org/your-dataset"
# HF_DATASET_SPLIT = "train"
